---
interface Profile {
  githubUrl: string;
  linkedinUrl: string | null;
  email: string | null;
  resumeUrl: string | null;
}

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
---
<div class="social-links">
  <a href={profile.githubUrl} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
    <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
      <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
    </svg>
  </a>
  {profile.linkedinUrl && (
    <a href={profile.linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
      <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M0 1.15C0 .52.52 0 1.15 0h13.7C15.48 0 16 .52 16 1.15v13.7c0 .63-.52 1.15-1.15 1.15H1.15C.52 16 0 15.48 0 14.85V1.15Zm4.94 12.13V6.16H2.5v7.12h2.44Zm-1.22-8.09c.85 0 1.38-.56 1.38-1.27-.02-.72-.53-1.27-1.36-1.27-.83 0-1.38.55-1.38 1.27 0 .71.53 1.27 1.34 1.27h.02Zm4.55 8.09V9.36c0-.24.02-.49.09-.66.2-.49.65-1 1.41-1 1 0 1.4.76 1.4 1.87v3.71h2.44V9.28c0-2.25-1.2-3.3-2.8-3.3-1.29 0-1.86.71-2.18 1.21h.02V6.16H6.21c.03.7 0 7.12 0 7.12h2.06Z"></path>
      </svg>
    </a>
  )}
  {profile.email && (
    <a href={`mailto:${profile.email}`} aria-label="Email">
      <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M1 4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4Zm1.2.2 5.8 4 5.8-4H2.2ZM14 5.4 8.4 9.2a.7.7 0 0 1-.8 0L2 5.4V12h12V5.4Z"></path>
      </svg>
    </a>
  )}
  {profile.resumeUrl && (
    <a href={profile.resumeUrl} target="_blank" rel="noopener noreferrer" aria-label="Resume">
      <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M4 1h5l3 3v11H4V1Zm4.5.5V4H11L8.5 1.5ZM5.5 8h5v1h-5V8Zm0 2h5v1h-5v-1Zm0 2h3v1h-3v-1Z"></path>
      </svg>
    </a>
  )}
</div>
